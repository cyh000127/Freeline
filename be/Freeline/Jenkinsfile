pipeline {
    agent { label 'build-agent-01' }

    environment {
        IMAGE_NAME = 'freeline-backend'
        COMPOSE_FILE = "${WORKSPACE}/infra/backend/docker-compose.yml"
    }

    triggers {
        gitlab(
            triggerOnPush: true,
            triggerOnMergeRequest: true,
            branchFilterType: 'NameBasedFilter',
            includeBranchesSpec: 'main'
        )
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Test & Build') {
            steps {
                dir('be/Freeline') {
                    sh 'chmod +x ./gradlew'
                    sh './gradlew clean build'
                }
            }
            post {
                always {
                    dir('be/Freeline') {
                        junit allowEmptyResults: true,
                             testResults: 'build/test-results/test/*.xml'
                    }
                }
            }
        }

        stage('Docker Build') {
            when {
                allOf {
                    branch 'main'
                    not { changeRequest() }
                }
            }
            steps {
                dir('be/Freeline') {
                    sh "docker build -t ${IMAGE_NAME}:${BUILD_NUMBER} -t ${IMAGE_NAME}:latest ."
                }
            }
        }

        stage('Deploy') {
            when {
                allOf {
                    branch 'main'
                    not { changeRequest() }
                }
            }
            steps {
                withCredentials([string(credentialsId: 'infisical-universal-auth', variable: 'INFISICAL_TOKEN')]) {
                    sh """
                        infisical run --env=prod --path="/be" --token=${INFISICAL_TOKEN} -- \
                            docker compose -f ${COMPOSE_FILE} up -d --force-recreate freeline-backend
                    """
                }
            }
        }
    }

    post {
        success {
            updateGitlabCommitStatus name: 'build', state: 'success'
        }
        failure {
            updateGitlabCommitStatus name: 'build', state: 'failed'
        }
        always {
            sh 'docker image prune -f --filter "until=24h" || true'
            cleanWs()
        }
    }
}
