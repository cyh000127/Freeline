pipeline {
    agent { label 'build-agent-01' }

    parameters {
        booleanParam(name: 'FORCE_REDEPLOY', defaultValue: false, description: '변경 감지 무시하고 강제 배포')
    }

    options {
        gitLabConnection('lab-ssafy')
    }

    environment {
        IMAGE_NAME = 'freeline-backend'
        COMPOSE_FILE = "${WORKSPACE}/infra/backend/docker-compose.yml"
        INFISICAL_URL = 'https://j14a207.p.ssafy.io:8443'
        INFISICAL_PROJECT_ID = credentials('infisical-project-id')
        INFISICAL_CLIENT_ID = credentials('infisical-client-id')
        INFISICAL_CLIENT_SECRET = credentials('infisical-client-secret')
    }

    triggers {
        gitlab(
            triggerOnPush: true,
            triggerOnMergeRequest: true,
            branchFilterType: 'All'
        )
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    if (env.gitlabSourceBranch) {
                        sh "git checkout origin/${env.gitlabSourceBranch}"
                    }
                }
            }
        }

        stage('Change Detection') {
            steps {
                script {
                    if (params.FORCE_REDEPLOY) {
                        echo "FORCE_REDEPLOY 활성화됨. 변경 감지 스킵."
                        return
                    }
                    def changes = getChangedFiles().split('\n').findAll { it.startsWith('be/') }
                    if (!changes) {
                        echo "be/ 폴더 변경 없음. 파이프라인 스킵."
                        currentBuild.result = 'NOT_BUILT'
                        error("No relevant changes in be/")
                    }
                    echo "변경 감지된 파일:\n${changes.join('\n')}"
                }
            }
        }

        stage('Test & Build') {
            steps {
                dir('be/Freeline') {
                    sh 'chmod +x ./gradlew'
                    sh '''set +x
                        export INFISICAL_TOKEN=$(infisical login --method=universal-auth \
                            --client-id=$INFISICAL_CLIENT_ID \
                            --client-secret=$INFISICAL_CLIENT_SECRET \
                            --domain=$INFISICAL_URL/api \
                            --silent --plain)
                        set -x
                        infisical run \
                            --domain=$INFISICAL_URL/api \
                            --projectId=$INFISICAL_PROJECT_ID \
                            --env=prod --path=/be \
                            -- ./gradlew clean build
                    '''
                }
            }
            post {
                always {
                    dir('be/Freeline') {
                        junit allowEmptyResults: true,
                            testResults: 'build/test-results/test/*.xml'
                    }
                }
            }
        }

        stage('Docker Build') {
            when { expression { isMainBranch() } }
            steps {
                dir('be/Freeline') {
                    sh "docker build -t ${IMAGE_NAME}:${BUILD_NUMBER} -t ${IMAGE_NAME}:latest ."
                }
            }
        }

        stage('Deploy') {
            when { expression { isMainBranch() } }
            steps {
                sh """set +x
                    export INFISICAL_TOKEN=\$(infisical login --method=universal-auth \
                        --client-id=\$INFISICAL_CLIENT_ID \
                        --client-secret=\$INFISICAL_CLIENT_SECRET \
                        --domain=\$INFISICAL_URL/api \
                        --silent --plain)
                    set -x
                    infisical run \
                        --domain=\$INFISICAL_URL/api \
                        --projectId=\$INFISICAL_PROJECT_ID \
                        --env=prod --path=/be \
                        -- docker compose -f ${COMPOSE_FILE} up -d --force-recreate freeline-backend
                """
                echo "Waiting for backend to stabilize..."
                sh '''
                    for i in $(seq 1 30); do
                        if curl -sf http://freeline-backend:8080/v3/api-docs > /dev/null; then
                            echo "\\nBackend is UP!"
                            exit 0
                        fi
                        echo -n "."
                        sleep 2
                    done
                    echo "\\nBackend failed to start in time."
                    exit 1
                '''
            }
        }
    }

    post {
        success {
            updateGitlabCommitStatus name: 'freeline-be', state: 'success'
        }
        notBuilt {
            updateGitlabCommitStatus name: 'freeline-be', state: 'success'
        }
        aborted {
            updateGitlabCommitStatus name: 'freeline-be', state: 'canceled'
        }
        failure {
            updateGitlabCommitStatus name: 'freeline-be', state: 'failed'
        }
        cleanup {
            sh 'docker image prune -f --filter "until=24h" || true'
            cleanWs()
        }
    }
}

// MR: origin/main 대비 전체 변경 파일, Push: 직전 커밋 대비
def getChangedFiles() {
    if (env.gitlabMergeRequestIid) {
        return sh(script: 'git diff --name-only origin/main...HEAD', returnStdout: true).trim()
    }
    return sh(
        script: 'git diff --name-only HEAD~1 HEAD 2>/dev/null || git log --name-only --pretty=format: -1 HEAD',
        returnStdout: true
    ).trim()
}

// main 브랜치 push 또는 수동 실행일 때 true (MR 이벤트 제외)
def isMainBranch() {
    if (env.gitlabMergeRequestIid) return false
    if (env.BRANCH_NAME == 'main' || env.gitlabBranch == 'main') return true
    // 수동 실행 시 (webhook 아님) 체크아웃된 브랜치로 판단
    def branch = sh(script: 'git rev-parse --abbrev-ref HEAD 2>/dev/null || true', returnStdout: true).trim()
    if (branch == 'HEAD') {
        // detached HEAD일 경우 main의 커밋인지 확인
        def onMain = sh(script: 'git branch -r --contains HEAD 2>/dev/null | grep -q origin/main && echo true || echo false', returnStdout: true).trim()
        return onMain == 'true'
    }
    return branch == 'main'
}
