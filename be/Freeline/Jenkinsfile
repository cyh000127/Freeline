pipeline {
    agent { label 'build-agent-01' }

    parameters {
        booleanParam(name: 'FORCE_REDEPLOY', defaultValue: false, description: '변경 감지 무시하고 강제 배포')
    }

    options {
        gitLabConnection('lab-ssafy')
    }

    environment {
        IMAGE_NAME = 'freeline-backend'
        COMPOSE_FILE = "${WORKSPACE}/infra/backend/docker-compose.yml"
    }

    triggers {
        gitlab(
            triggerOnPush: true,
            triggerOnMergeRequest: true,
            branchFilterType: 'All'
        )
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    if (env.gitlabSourceBranch) {
                        sh "git checkout origin/${env.gitlabSourceBranch}"
                    }
                }
            }
        }

        stage('Change Detection') {
            steps {
                script {
                    if (params.FORCE_REDEPLOY) {
                        echo "FORCE_REDEPLOY 활성화됨. 변경 감지 스킵."
                        return
                    }
                    def changes = getChangedFiles().split('\n').findAll { it.startsWith('be/') }
                    if (!changes) {
                        echo "be/ 폴더 변경 없음. 파이프라인 스킵."
                        currentBuild.result = 'NOT_BUILT'
                        error("No relevant changes in be/")
                    }
                    echo "변경 감지된 파일:\n${changes.join('\n')}"
                }
            }
        }

        stage('Test & Build') {
            steps {
                withInfisical(
                    configuration: [
                        infisicalCredentialId: 'infisical-universal-auth',
                        infisicalEnvironmentSlug: 'prod',
                        infisicalProjectSlug: 'freeline',
                        infisicalUrl: 'https://j14a207.p.ssafy.io:8443'
                    ],
                    infisicalSecrets: [
                        infisicalSecret(
                            includeImports: true,
                            path: '/be',
                            secretValues: [
                                [infisicalKey: 'CLOUDFLARE_ACCESS_KEY'],
                                [infisicalKey: 'CLOUDFLARE_BUCKET'],
                                [infisicalKey: 'CLOUDFLARE_ENDPOINT'],
                                [infisicalKey: 'CLOUDFLARE_OUTER_PREFIX'],
                                [infisicalKey: 'CLOUDFLARE_SECRET_KEY'],
                                [infisicalKey: 'DB_HOST'],
                                [infisicalKey: 'DB_NAME'],
                                [infisicalKey: 'DB_PASSWORD'],
                                [infisicalKey: 'DB_PORT'],
                                [infisicalKey: 'DB_USERNAME'],
                                [infisicalKey: 'EMAIL_CODE_EXPIRE_MINUTES'],
                                [infisicalKey: 'ENCRYPTION_SECRET_KEY'],
                                [infisicalKey: 'FIREBASE_PROJECT_ID'],
                                [infisicalKey: 'FIREBASE_SERVICE_ACCOUNT_BASE64'],
                                [infisicalKey: 'JWT_ACCESS_TOKEN_EXPIRATION'],
                                [infisicalKey: 'JWT_REFRESH_TOKEN_EXPIRATION'],
                                [infisicalKey: 'JWT_SECRET'],
                                [infisicalKey: 'MAIL_PASSWORD'],
                                [infisicalKey: 'MAIL_USERNAME'],
                                [infisicalKey: 'RABBITMQ_HOST'],
                                [infisicalKey: 'RABBITMQ_PASSWORD'],
                                [infisicalKey: 'RABBITMQ_PORT'],
                                [infisicalKey: 'RABBITMQ_USERNAME'],
                                [infisicalKey: 'RABBITMQ_VIRTUAL_HOST'],
                                [infisicalKey: 'REDIS_HOST'],
                                [infisicalKey: 'REDIS_PASSWORD'],
                                [infisicalKey: 'REDIS_PORT'],
                                [infisicalKey: 'SPRING_PROFILES_ACTIVE']
                            ]
                        )
                    ]
                ) {
                    dir('be/Freeline') {
                        sh 'chmod +x ./gradlew'
                        sh './gradlew clean build'
                    }
                }
            }
            post {
                always {
                    dir('be/Freeline') {
                        junit allowEmptyResults: true,
                            testResults: 'build/test-results/test/*.xml'
                    }
                }
            }
        }

        stage('Docker Build') {
            when { expression { isMainBranch() } }
            steps {
                dir('be/Freeline') {
                    sh "docker build -t ${IMAGE_NAME}:${BUILD_NUMBER} -t ${IMAGE_NAME}:latest ."
                }
            }
        }

        stage('Deploy') {
            when { expression { isMainBranch() } }
            steps {
                withInfisical(
                    configuration: [
                        infisicalCredentialId: 'infisical-universal-auth',
                        infisicalEnvironmentSlug: 'prod',
                        infisicalProjectSlug: 'freeline',
                        infisicalUrl: 'https://j14a207.p.ssafy.io:8443'
                    ],
                    infisicalSecrets: [
                        infisicalSecret(
                            includeImports: true,
                            path: '/be',
                            secretValues: [
                                [infisicalKey: 'DB_NAME'],
                                [infisicalKey: 'DB_USERNAME'],
                                [infisicalKey: 'DB_PASSWORD'],
                                [infisicalKey: 'REDIS_PASSWORD'],
                                [infisicalKey: 'JWT_SECRET'],
                                [infisicalKey: 'JWT_ACCESS_TOKEN_EXPIRATION'],
                                [infisicalKey: 'JWT_REFRESH_TOKEN_EXPIRATION'],
                                [infisicalKey: 'ENCRYPTION_SECRET_KEY'],
                                [infisicalKey: 'CLOUDFLARE_ACCESS_KEY'],
                                [infisicalKey: 'CLOUDFLARE_BUCKET'],
                                [infisicalKey: 'CLOUDFLARE_ENDPOINT'],
                                [infisicalKey: 'CLOUDFLARE_OUTER_PREFIX'],
                                [infisicalKey: 'CLOUDFLARE_SECRET_KEY'],
                                [infisicalKey: 'FIREBASE_PROJECT_ID'],
                                [infisicalKey: 'FIREBASE_SERVICE_ACCOUNT_BASE64'],
                                [infisicalKey: 'MAIL_USERNAME'],
                                [infisicalKey: 'MAIL_PASSWORD'],
                                [infisicalKey: 'RABBITMQ_HOST'],
                                [infisicalKey: 'RABBITMQ_PASSWORD'],
                                [infisicalKey: 'RABBITMQ_PORT'],
                                [infisicalKey: 'RABBITMQ_USERNAME'],
                                [infisicalKey: 'RABBITMQ_VIRTUAL_HOST'],
                                [infisicalKey: 'MAIL_PASSWORD'],
                                [infisicalKey: 'EMAIL_CODE_EXPIRE_MINUTES'],
                                [infisicalKey: 'SPRING_PROFILES_ACTIVE']
                            ]
                        )
                    ]
                ) {
                    sh "docker compose -f ${COMPOSE_FILE} up -d --force-recreate freeline-backend"
                }
                echo "Waiting for backend to stabilize..."
                sh '''
                    for i in $(seq 1 30); do
                        if curl -sf http://freeline-backend:8080/v3/api-docs > /dev/null; then
                            echo "\\nBackend is UP!"
                            exit 0
                        fi
                        echo -n "."
                        sleep 2
                    done
                    echo "\\nBackend failed to start in time."
                    exit 1
                '''
            }
        }
    }

    post {
        success {
            updateGitlabCommitStatus name: 'freeline-be', state: 'success'
        }
        notBuilt {
            updateGitlabCommitStatus name: 'freeline-be', state: 'success'
        }
        aborted {
            updateGitlabCommitStatus name: 'freeline-be', state: 'canceled'
        }
        failure {
            updateGitlabCommitStatus name: 'freeline-be', state: 'failed'
        }
        cleanup {
            sh 'docker image prune -f --filter "until=24h" || true'
            cleanWs()
        }
    }
}

// MR: origin/main 대비 전체 변경 파일, Push: 직전 커밋 대비
def getChangedFiles() {
    if (env.gitlabMergeRequestIid) {
        return sh(script: 'git diff --name-only origin/main...HEAD', returnStdout: true).trim()
    }
    return sh(
        script: 'git diff --name-only HEAD~1 HEAD 2>/dev/null || git log --name-only --pretty=format: -1 HEAD',
        returnStdout: true
    ).trim()
}

// main 브랜치 push 또는 수동 실행일 때 true (MR 이벤트 제외)
def isMainBranch() {
    if (env.gitlabMergeRequestIid) return false
    if (env.BRANCH_NAME == 'main' || env.gitlabBranch == 'main') return true
    // 수동 실행 시 (webhook 아님) 체크아웃된 브랜치로 판단
    def branch = sh(script: 'git rev-parse --abbrev-ref HEAD 2>/dev/null || true', returnStdout: true).trim()
    if (branch == 'HEAD') {
        // detached HEAD일 경우 main의 커밋인지 확인
        def onMain = sh(script: 'git branch -r --contains HEAD 2>/dev/null | grep -q origin/main && echo true || echo false', returnStdout: true).trim()
        return onMain == 'true'
    }
    return branch == 'main'
}
