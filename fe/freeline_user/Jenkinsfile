pipeline {
    agent {
        label 'build-agent-01'
    }

    environment {
        DOCKER_IMAGE = "freeline-frontend"
        DOCKER_TAG = "${env.BUILD_ID}"
        COMPOSE_FILE = "${env.WORKSPACE}/infra/frontend/docker-compose.yml"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Change Detection') {
            steps {
                script {
                    def changes = sh(
                        script: "git diff --name-only HEAD~1 HEAD | grep '^fe/' || true",
                        returnStdout: true
                    ).trim()
                    if (!changes) {
                        echo "fe/ 폴더 변경 없음. 파이프라인 스킵."
                        currentBuild.result = 'NOT_BUILT'
                        error("No relevant changes in fe/")
                    }
                    echo "변경 감지된 파일:\n${changes}"
                }
            }
        }

        stage('Docker Build with Secrets') {
            steps {
                // 프론트엔드쪽 Infisical path 및 필요한 키들을 맞게 수정 필요
                withInfisical(
                    configuration: [
                        infisicalCredentialId: 'infisical-universal-auth',
                        infisicalEnvironmentSlug: 'prod',
                        infisicalProjectSlug: 'freeline',
                        infisicalUrl: 'https://j14a207.p.ssafy.io:8443'
                    ],
                    infisicalSecrets: [
                        infisicalSecret(
                            includeImports: true,
                            path: '/fe',  // 백엔드의 /be 대신 /fe 사용 (환경에 맞게 수정)
                            secretValues: [
                                // 여기에 FE 앱 빌드 시 들어갈 환경 변수들을 바인딩
                                // [infisicalKey: 'EXPO_PUBLIC_API_URL'],
                            ]
                        )
                    ]
                ) {
                    dir('fe/freeline_user') {
                        // 필요한 환경 변수가 있을경우 --build-arg 형태로 컨테이너 빌드 시 전달합니다.
                        // sh "docker build --build-arg EXPO_PUBLIC_API_URL=${EXPO_PUBLIC_API_URL} -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                        sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                        sh "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest"
                    }
                }
            }
        }

        stage('Deploy') {
            when {
                expression { env.gitlabMergeRequestIid == null && env.gitlabBranch == 'main' }
            }
            steps {
                sh "docker compose -f ${COMPOSE_FILE} up -d --force-recreate freeline-frontend"
                
                echo "Waiting for frontend to stabilize..."
                sh '''
                    for i in $(seq 1 15); do
                        if curl -sf http://freeline-frontend:80 > /dev/null; then
                            echo "\\nFrontend is UP!"
                            exit 0
                        fi
                        echo -n "."
                        sleep 2
                    done
                    echo "\\nFrontend failed to start in time or is unhealthy."
                    exit 1
                '''
            }
        }
    }

    post {
        success {
            updateGitlabCommitStatus name: 'build', state: 'success'
        }
        notBuilt {
            updateGitlabCommitStatus name: 'build', state: 'success'
        }
        aborted {
            updateGitlabCommitStatus name: 'build', state: 'canceled'
        }
        failure {
            updateGitlabCommitStatus name: 'build', state: 'failed'
        }
        always {
            sh "docker image prune -f --filter until=24h"
            cleanWs()
        }
    }
}
