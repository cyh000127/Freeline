{
  "cli": {
    "version": ">= 16.22.0",
    "requireCommit": true
  },
  "build": {
    "base": {
      "android": {
        "image": "latest"
      }
    },
    "dev-apk": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "dev",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "extends": "base",
      "distribution": "internal",
      "channel": "production",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "production"
      },
      "autoIncrement": false
    }
  },
  "submit": {
    "production": {}
  }
}
