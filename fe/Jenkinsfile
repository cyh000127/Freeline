pipeline {
    agent { label 'build-agent-01' }

    parameters {
        booleanParam(name: 'FORCE_REDEPLOY', defaultValue: false, description: '변경 감지 무시하고 강제 배포')
    }

    options {
        gitLabConnection('lab-ssafy')
    }

    triggers {
        gitlab(
            triggerOnPush: true,
            triggerOnMergeRequest: true,
            branchFilterType: 'All'
        )
    }

    environment {
        COMPOSE_FILE = "${env.WORKSPACE}/infra/frontend/docker-compose.yml"

        USER_IMAGE  = 'freeline-frontend'
        BOOTH_IMAGE = 'freeline-booth'
        SUPER_IMAGE = 'freeline-super'

        DOCKER_TAG = "${env.BUILD_ID}"

        APK_DIR = '/opt/freeline/apk'
        USER_RELEASE_ACTION = 'none'

        INFISICAL_URL = 'https://j14a207.p.ssafy.io:8443'
        INFISICAL_PROJECT_ID = credentials('infisical-project-id')
        INFISICAL_CLIENT_ID = credentials('infisical-client-id')
        INFISICAL_CLIENT_SECRET = credentials('infisical-client-secret')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                updateGitlabCommitStatus name: 'freeline-fe', state: 'pending'
                script {
                    if (env.gitlabSourceBranch) {
                        sh "git checkout origin/${env.gitlabSourceBranch}"
                    }
                }
            }
        }

        stage('Change Detection') {
            steps {
                script {
                    if (params.FORCE_REDEPLOY) {
                        echo "FORCE_REDEPLOY 활성화됨. 모든 프론트엔드 빌드 대상으로 설정."
                        env.BUILD_USER  = 'true'
                        env.BUILD_BOOTH = 'true'
                        env.BUILD_SUPER = 'true'
                        env.USER_RELEASE_ACTION = 'build'
                        return
                    }

                    def changes = getChangedFiles()

                    env.BUILD_USER  = 'false'
                    env.BUILD_BOOTH = 'false'
                    env.BUILD_SUPER = 'false'

                    if (!changes || changes.contains('fe/types/')) {
                        env.BUILD_USER  = 'true'
                        env.BUILD_BOOTH = 'true'
                        env.BUILD_SUPER = 'true'
                    } else {
                        if (changes.contains('fe/freeline-user/'))  { env.BUILD_USER  = 'true' }
                        if (changes.contains('fe/freeline-booth/')) { env.BUILD_BOOTH = 'true' }
                        if (changes.contains('fe/freeline-super/')) { env.BUILD_SUPER = 'true' }
                    }

                    if (env.BUILD_USER == 'false' && env.BUILD_BOOTH == 'false' && env.BUILD_SUPER == 'false') {
                        echo "fe/ 폴더 관련 앱 변경 없음. 파이프라인 스킵."
                        currentBuild.result = 'NOT_BUILT'
                        error('No relevant changes in fe/')
                    }

                    env.USER_RELEASE_ACTION = env.BUILD_USER == 'true'
                        ? (hasUserNativeChanges(changes) ? 'build' : 'update')
                        : 'none'

                    echo "Build User: ${env.BUILD_USER}, Build Booth: ${env.BUILD_BOOTH}, Build Super: ${env.BUILD_SUPER}"
                    echo "User Release Action: ${env.USER_RELEASE_ACTION}"
                    echo "Changed files:\n${changes}"
                }
            }
        }

        stage('Build') {
            parallel {
                stage('Build freeline-user') {
                    when { expression { env.BUILD_USER == 'true' } }
                    steps {
                        dir('fe/freeline-user') {
                            sh '''set +x
                                export INFISICAL_TOKEN=$(infisical login --method=universal-auth \
                                    --client-id=$INFISICAL_CLIENT_ID \
                                    --client-secret=$INFISICAL_CLIENT_SECRET \
                                    --domain=$INFISICAL_URL/api \
                                    --silent --plain)
                                set -x
                                infisical run \
                                    --domain=$INFISICAL_URL/api \
                                    --projectId=$INFISICAL_PROJECT_ID \
                                    --env=prod --path=/fe \
                                    -- docker build -t $USER_IMAGE:$DOCKER_TAG -t $USER_IMAGE:latest .
                            '''
                        }
                    }
                }

                stage('Build freeline-booth') {
                    when { expression { env.BUILD_BOOTH == 'true' } }
                    steps {
                        dir('fe/freeline-booth') {
                            sh '''set +x
                                export INFISICAL_TOKEN=$(infisical login --method=universal-auth \
                                    --client-id=$INFISICAL_CLIENT_ID \
                                    --client-secret=$INFISICAL_CLIENT_SECRET \
                                    --domain=$INFISICAL_URL/api \
                                    --silent --plain)
                                set -x
                                infisical run \
                                    --domain=$INFISICAL_URL/api \
                                    --projectId=$INFISICAL_PROJECT_ID \
                                    --env=prod --path=/fe \
                                    -- docker build -t $BOOTH_IMAGE:$DOCKER_TAG -t $BOOTH_IMAGE:latest .
                            '''
                        }
                    }
                }

                stage('Build freeline-super') {
                    when { expression { env.BUILD_SUPER == 'true' } }
                    steps {
                        dir('fe/freeline-super') {
                            sh '''set +x
                                export INFISICAL_TOKEN=$(infisical login --method=universal-auth \
                                    --client-id=$INFISICAL_CLIENT_ID \
                                    --client-secret=$INFISICAL_CLIENT_SECRET \
                                    --domain=$INFISICAL_URL/api \
                                    --silent --plain)
                                set -x
                                infisical run \
                                    --domain=$INFISICAL_URL/api \
                                    --projectId=$INFISICAL_PROJECT_ID \
                                    --env=prod --path=/fe \
                                    -- docker build -t $SUPER_IMAGE:$DOCKER_TAG -t $SUPER_IMAGE:latest .
                            '''
                        }
                    }
                }
            }
        }

        stage('Deploy') {
            when { expression { isMainBranch() } }
            steps {
                sh "docker compose -f ${COMPOSE_FILE} up -d"

                echo "Waiting for frontends to stabilize..."
                sh '''
                    for i in $(seq 1 15); do
                        SUCCESS=true
                        if ! docker inspect --format='{{.State.Running}}' freeline-frontend 2>/dev/null | grep -q true; then SUCCESS=false; fi
                        if [ "$BUILD_BOOTH" = "true" ] && ! docker inspect --format='{{.State.Running}}' freeline-booth 2>/dev/null | grep -q true; then SUCCESS=false; fi
                        if [ "$BUILD_SUPER" = "true" ] && ! docker inspect --format='{{.State.Running}}' freeline-super 2>/dev/null | grep -q true; then SUCCESS=false; fi

                        if [ "$SUCCESS" = "true" ]; then
                            echo "\\nFrontends are UP!"
                            exit 0
                        fi
                        echo -n "."
                        sleep 2
                    done
                    echo "\\nSome frontends failed to start in time."
                    exit 1
                '''
            }
        }

        stage('Release User App') {
            when {
                allOf {
                    expression { isMainBranch() }
                    expression { env.BUILD_USER == 'true' }
                }
            }
            steps {
                dir('fe/freeline-user') {
                    sh '''set -eu
                        set +x
                        export INFISICAL_TOKEN=$(infisical login --method=universal-auth \
                            --client-id=$INFISICAL_CLIENT_ID \
                            --client-secret=$INFISICAL_CLIENT_SECRET \
                            --domain=$INFISICAL_URL/api \
                            --silent --plain)
                        set -x

                        # Infisical에서 EXPO_TOKEN, EAS_PROJECT_ID 주입
                        infisical run \
                            --domain=$INFISICAL_URL/api \
                            --projectId=$INFISICAL_PROJECT_ID \
                            --env=prod --path=/fe \
                            -- bash -s -- <<'EOF'
                                set -euo pipefail

                                command -v docker >/dev/null 2>&1 || { echo "ERROR: docker not found on Jenkins agent"; exit 1; }

                                : "${EXPO_TOKEN:?ERROR: EXPO_TOKEN is missing from Infisical /fe}"
                                : "${EAS_PROJECT_ID:?ERROR: EAS_PROJECT_ID is missing from Infisical /fe}"

                                action="${USER_RELEASE_ACTION:-build}"
                                case "$action" in
                                    update|build) ;;
                                    *)
                                        echo "ERROR: invalid USER_RELEASE_ACTION='$action'"
                                        exit 1
                                        ;;
                                esac

                                # Agent에 npm/npx가 없어도 동작하도록 Node 컨테이너에서 EAS 명령 실행
                                docker run --rm \
                                    -e EXPO_TOKEN \
                                    -e EAS_PROJECT_ID \
                                    -e USER_RELEASE_ACTION="$action" \
                                    -e BUILD_ID="${BUILD_ID:-0}" \
                                    -v "$PWD:/app" \
                                    -w /app \
                                    node:20-bullseye \
                                    bash -lc '
                                        set -euo pipefail
                                        npm ci
                                        if [ "$USER_RELEASE_ACTION" = "update" ]; then
                                            npx eas-cli update \
                                                --channel production \
                                                --platform android \
                                                --non-interactive \
                                                --message "jenkins-${BUILD_ID}"
                                        else
                                            mkdir -p ./build
                                            npx eas-cli build -p android \
                                                --profile production \
                                                --non-interactive \
                                                --wait \
                                                --output ./build/freeline.apk
                                        fi
                                    '

                                if [ "$action" = "update" ]; then
                                    echo "EAS update published (channel=production, platform=android)"
                                else
                                    # /opt 경로 권한 이슈를 피하기 위해 Docker root 권한으로 복사
                                    docker run --rm \
                                        -v "$PWD/build:/src:ro" \
                                        -v "$APK_DIR:/dest" \
                                        alpine:3.20 \
                                        sh -c 'set -eu; test -f /src/freeline.apk; cp /src/freeline.apk /dest/freeline.apk'
                                    echo "APK deployed: https://j14a207.p.ssafy.io/app/freeline.apk"
                                fi
EOF
                    '''
                }
            }
        }
    }

    post {
        success {
            updateGitlabCommitStatus name: 'freeline-fe', state: 'success'
        }
        notBuilt {
            updateGitlabCommitStatus name: 'freeline-fe', state: 'success'
        }
        aborted {
            updateGitlabCommitStatus name: 'freeline-fe', state: 'canceled'
        }
        failure {
            updateGitlabCommitStatus name: 'freeline-fe', state: 'failed'
        }
        cleanup {
            sh """
                # 현재 빌드 + latest 외 이전 태그 이미지 삭제
                for img in ${USER_IMAGE} ${BOOTH_IMAGE} ${SUPER_IMAGE}; do
                    docker images "\$img" --format '{{.Tag}}' \
                        | grep -v -E '^(latest|${DOCKER_TAG})\$' \
                        | xargs -r -I{} docker rmi "\$img:{}" 2>/dev/null || true
                done
                # dangling 이미지 정리
                docker image prune -f || true
                # 7일 지난 빌드 캐시 정리
                docker builder prune -f --filter 'until=168h' 2>/dev/null || true
            """
            cleanWs()
        }
    }
}

def getChangedFiles() {
    if (env.gitlabMergeRequestIid) {
        return sh(script: 'git diff --name-only origin/main...HEAD', returnStdout: true).trim()
    }
    return sh(
        script: 'git diff --name-only HEAD~1 HEAD 2>/dev/null || git log --name-only --pretty=format: -1 HEAD',
        returnStdout: true
    ).trim()
}

def hasUserNativeChanges(final String changes) {
    if (!changes) {
        return false
    }

    def nativeSensitivePaths = [
        'fe/freeline-user/app.json',
        'fe/freeline-user/app.config.ts',
        'fe/freeline-user/eas.json',
        'fe/freeline-user/package.json',
        'fe/freeline-user/package-lock.json',
        'fe/freeline-user/android/',
        'fe/freeline-user/ios/'
    ]

    return nativeSensitivePaths.any { path -> changes.contains(path) }
}

// main 브랜치 push 또는 수동 실행일 때 true (MR 이벤트 제외)
def isMainBranch() {
    if (env.gitlabMergeRequestIid) return false
    if (env.BRANCH_NAME == 'main' || env.gitlabBranch == 'main') return true
    def branch = sh(script: 'git rev-parse --abbrev-ref HEAD 2>/dev/null || true', returnStdout: true).trim()
    if (branch == 'HEAD') {
        def onMain = sh(script: 'git branch -r --contains HEAD 2>/dev/null | grep -q origin/main && echo true || echo false', returnStdout: true).trim()
        return onMain == 'true'
    }
    return branch == 'main'
}
