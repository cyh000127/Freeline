{
  "name": "freeline-user",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "apk:configure": "npx eas-cli build:configure",
    "apk:update:configure": "npx eas-cli update:configure",
    "apk:build:dev": "npx eas-cli build -p android --profile dev-apk",
    "apk:build:preview": "npx eas-cli build -p android --profile preview",
    "apk:build:prod": "npx eas-cli build -p android --profile production --non-interactive",
    "apk:build:local": "npx eas-cli build -p android --profile production --local --output ./build/freeline.apk",
    "apk:list": "npx eas-cli build:list --platform android --limit 10",
    "apk:download": "npx eas-cli build:list --platform android --status finished --limit 1 --json | node -e \"const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));if(d[0]?.artifacts?.buildUrl)console.log(d[0].artifacts.buildUrl);else process.exit(1)\"",
    "apk:install:latest": "npx eas-cli build:run -p android --latest",
    "apk:update": "npx eas-cli update --channel production --platform android"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/native": "^7.1.8",
    "axios": "^1.13.6",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.8",
    "expo-constants": "~18.0.13",
    "expo-image": "~3.0.11",
    "expo-notifications": "~0.32.12",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "jwt-decode": "^4.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "description": "",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
