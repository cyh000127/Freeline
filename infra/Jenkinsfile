pipeline {
    agent any

    parameters {
        booleanParam(name: 'DEPLOY_ALL', defaultValue: false, description: '변경 감지 무시하고 모든 컴포넌트 배포')
        string(name: 'SSH_CREDENTIALS_ID', defaultValue: 'infra-ssh-key', description: 'Jenkins SSH Credentials ID')
    }

    environment {
        INFRA_DIR    = 'infra'
        HOSTS_FILE   = 'infra/hosts.conf'
        // 배포 순서 정의: networks는 반드시 먼저, nginx는 마지막
        DEPLOY_ORDER = 'networks,infisical,jenkins,monitoring,backend,frontend,nginx'
    }

    stages {

        stage('Change Detection') {
            steps {
                script {
                    def changes = sh(
                        script: "git diff --name-only HEAD~1 HEAD | grep '^infra/' || true",
                        returnStdout: true
                    ).trim()
                    if (!changes && !params.DEPLOY_ALL) {
                        echo "infra/ 폴더 변경 없음. 파이프라인 스킵."
                        currentBuild.result = 'NOT_BUILT'
                        error("No relevant changes in infra/")
                    }
                    echo "변경 감지된 파일:\n${changes}"
                }
            }
        }

        stage('Load Host Mapping') {
            steps {
                script {
                    // hosts.conf를 읽어 컴포넌트→호스트 맵 생성
                    def hostMap = [:]
                    def lines = readFile(env.HOSTS_FILE).split('\n')
                    lines.each { line ->
                        line = line.trim()
                        if (line && !line.startsWith('#')) {
                            def parts = line.split('=', 2)
                            if (parts.size() == 2) {
                                hostMap[parts[0].trim()] = parts[1].trim()
                            }
                        }
                    }
                    env.HOST_MAP_JSON = groovy.json.JsonOutput.toJson(hostMap)
                    echo "Host mapping loaded: ${env.HOST_MAP_JSON}"
                }
            }
        }

        stage('Detect Changes') {
            steps {
                script {
                    def orderedComponents = env.DEPLOY_ORDER.split(',').toList()

                    if (params.DEPLOY_ALL) {
                        echo "DEPLOY_ALL: 모든 컴포넌트 배포 대상"
                        env.CHANGED_COMPONENTS = orderedComponents.findAll { comp ->
                            fileExists("${env.INFRA_DIR}/${comp}/docker-compose.yml")
                        }.join(',')
                    } else {
                        def changedFiles = sh(
                            script: "git diff --name-only ${env.GIT_PREVIOUS_COMMIT ?: 'HEAD~1'} HEAD",
                            returnStdout: true
                        ).trim().split('\n')

                        def changedSet = [] as Set
                        changedFiles.each { file ->
                            if (file.startsWith("${env.INFRA_DIR}/")) {
                                def component = file.split('/')[1]
                                if (fileExists("${env.INFRA_DIR}/${component}/docker-compose.yml")) {
                                    changedSet.add(component)
                                }
                            }
                        }

                        // 정의된 순서대로 정렬하여 의존성 보장
                        env.CHANGED_COMPONENTS = orderedComponents.findAll { changedSet.contains(it) }.join(',')
                    }

                    if (!env.CHANGED_COMPONENTS) {
                        echo "변경된 인프라 컴포넌트 없음. 배포 스킵."
                    } else {
                        echo "배포 대상 (순서 보장): ${env.CHANGED_COMPONENTS}"
                    }
                }
            }
        }

        stage('Ensure Networks on All Hosts') {
            when {
                expression { env.CHANGED_COMPONENTS }
            }
            steps {
                script {
                    def hostMap = new HashMap(new groovy.json.JsonSlurper().parseText(env.HOST_MAP_JSON))
                    def targetHosts = env.CHANGED_COMPONENTS.split(',').collect { hostMap[it] ?: 'localhost' }.unique()

                    targetHosts.each { host ->
                        echo "네트워크 확인: ${host}"
                        // docker network create는 이미 존재하면 무시 (Agent 재시작 방지)
                        ensureNetwork('infra-public', host, params.SSH_CREDENTIALS_ID)
                    }
                }
            }
        }

        stage('Deploy Components') {
            when {
                expression { env.CHANGED_COMPONENTS }
            }
            steps {
                script {
                    def hostMap = new HashMap(new groovy.json.JsonSlurper().parseText(env.HOST_MAP_JSON))
                    def components = env.CHANGED_COMPONENTS.split(',')

                    components.each { component ->
                        if (component == 'networks') return // 이미 위에서 처리

                        def targetHost = hostMap[component] ?: 'localhost'
                        stage("Deploy: ${component} → ${targetHost}") {
                            deployComponent(component, targetHost, params.SSH_CREDENTIALS_ID)
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            echo '✅ Infrastructure CI/CD completed successfully.'
        }
        failure {
            echo '❌ Infrastructure CI/CD failed. Please check logs.'
        }
    }
}

// ──────────────────────────────────────────────
// Helper: Docker 네트워크를 안전하게 생성 (이미 있으면 무시)
// ──────────────────────────────────────────────
def ensureNetwork(String networkName, String host, String sshCredId) {
    def cmd = "docker network create ${networkName} 2>/dev/null || echo 'Network ${networkName} already exists'"
    if (host == 'localhost' || host == '127.0.0.1') {
        sh cmd
    } else {
        withCredentials([sshUserPrivateKey(credentialsId: sshCredId, keyFileVariable: 'SSH_KEY')]) {
            sh "ssh -i \$SSH_KEY -o StrictHostKeyChecking=no ${host} '${cmd}'"
        }
    }
}

// ──────────────────────────────────────────────
// Helper: 컴포넌트를 로컬 또는 원격 호스트에 배포
// ──────────────────────────────────────────────
def deployComponent(String component, String host, String sshCredId) {
    if (host == 'localhost' || host == '127.0.0.1') {
        sh "infra/scripts/deploy.sh ${component}"
    } else {
        withCredentials([sshUserPrivateKey(credentialsId: sshCredId, keyFileVariable: 'SSH_KEY')]) {
            def remoteBase = '/home/ubuntu/infra'
            sh "ssh -i \$SSH_KEY -o StrictHostKeyChecking=no ${host} 'mkdir -p ${remoteBase}/scripts'"
            sh "scp -i \$SSH_KEY -o StrictHostKeyChecking=no -r infra/${component} ${host}:${remoteBase}/"
            sh "scp -i \$SSH_KEY -o StrictHostKeyChecking=no infra/scripts/deploy.sh ${host}:${remoteBase}/scripts/"
            sh "ssh -i \$SSH_KEY -o StrictHostKeyChecking=no ${host} 'chmod +x ${remoteBase}/scripts/deploy.sh && ${remoteBase}/scripts/deploy.sh ${component}'"
        }
    }
}
