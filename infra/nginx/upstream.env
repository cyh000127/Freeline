# Nginx upstream host configuration
# Used by envsubst to generate default.conf from default.conf.template
#
# When services are on the same Docker network (same server):
#   Use container names (e.g., freeline-backend, jenkins)
#
# When services are on separate servers:
#   Use actual IP addresses (e.g., 10.0.0.2)

SERVER_NAME=j14a207.p.ssafy.io

# BE/FE는 같은 서버 (Server A) → 컨테이너명 사용
BACKEND_HOST=freeline-backend
BACKEND_PORT=8080

FRONTEND_HOST=freeline-frontend
FRONTEND_PORT=80

BOOTH_HOST=freeline-booth
BOOTH_PORT=3000

SUPER_HOST=freeline-super
SUPER_PORT=3000

# Jenkins/Infisical은 Server B → 내부 IP + 외부 포트 사용
JENKINS_HOST=172.26.15.39
JENKINS_PORT=8090

INFISICAL_HOST=172.26.15.39
INFISICAL_PORT=8081

# Monitoring (Server B)
GRAFANA_HOST=172.26.15.39
GRAFANA_PORT=3000

PROMETHEUS_HOST=172.26.15.39
PROMETHEUS_PORT=9090

# RabbitMQ (Server A, same Docker network)
RABBITMQ_HOST=freeline-rabbitmq
RABBITMQ_MGMT_PORT=15672
