      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Checks (Pass / Fail)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(increase(k6_checks_total{testid=~\"$testid\"}[30s])) - sum(increase(k6_checks_total{testid=~\"$testid\"}[30s])) * 0",
          "legendFormat": "Passed"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
