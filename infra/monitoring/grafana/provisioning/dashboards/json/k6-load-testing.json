      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Iterations",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(increase(k6_iterations_total{testid=~\"$testid\"}[$__range]))",
          "legendFormat": "Iterations"
        }
      ]
